generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  USER
  VIEWER
}

enum SupplierType {
  TIER1_FACTORY
  MILL
  SPINNER
  DYEHOUSE
  TRIM_SUPPLIER
  AGENT
  OTHER
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
  PROSPECT
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  UNKNOWN
}

enum DocumentStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  EXPIRED
}

model User {
  id                   String               @id @default(cuid())
  email                String               @unique
  passwordHash         String
  name                 String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  organizations        UserOrganization[]
  uploadedDocuments    Document[]           @relation("UploadedDocuments")
  reviewedDocuments    Document[]           @relation("ReviewedDocuments")
  notifications        Notification[]
  passwordResetTokens  PasswordResetToken[]
}

// ─── Phase 10: Password Reset ─────────────────────────────────────

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  tokenHash String    @unique // SHA-256 hash of the raw token
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([tokenHash])
  @@index([userId])
}

model Organization {
  id                 String             @id @default(cuid())
  name               String
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  industry           String?
  supplierCount      String?
  primaryConcern     String?
  onboardingComplete Boolean            @default(false)
  members            UserOrganization[]
  suppliers          Supplier[]
  documentTypes      DocumentType[]
  documents          Document[]
  products           Product[]
  notifications      Notification[]
}

model UserOrganization {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  role           Role
  createdAt      DateTime     @default(now())

  @@unique([userId, organizationId])
}

model Supplier {
  id           String            @id @default(cuid())
  orgId        String
  org          Organization      @relation(fields: [orgId], references: [id])
  name         String
  supplierCode String?
  type         SupplierType
  country      String
  city         String?
  status       SupplierStatus    @default(ACTIVE)
  riskLevel    RiskLevel         @default(UNKNOWN)
  notes        String?
  contacts     Contact[]
  documents    Document[]
  productLinks ProductSupplier[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model Contact {
  id         String   @id @default(cuid())
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])
  name       String
  email      String?
  phone      String?
  role       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model DocumentType {
  id                       String         @id @default(cuid())
  orgId                    String
  org                      Organization   @relation(fields: [orgId], references: [id])
  name                     String
  description              String?
  requiredForSupplierTypes SupplierType[] @default([])
  isActive                 Boolean        @default(true)
  documents                Document[]
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt
}

model Document {
  id               String         @id @default(cuid())
  orgId            String
  org              Organization   @relation(fields: [orgId], references: [id])
  supplierId       String
  supplier         Supplier       @relation(fields: [supplierId], references: [id])
  documentTypeId   String
  documentType     DocumentType   @relation(fields: [documentTypeId], references: [id])
  fileUrl          String
  filename         String
  mimeType         String
  issuedDate       DateTime?
  expiryDate       DateTime?
  status           DocumentStatus @default(PENDING_REVIEW)
  uploadedByUserId String
  uploadedBy       User           @relation("UploadedDocuments", fields: [uploadedByUserId], references: [id])
  reviewedByUserId String?
  reviewedBy       User?          @relation("ReviewedDocuments", fields: [reviewedByUserId], references: [id])
  reviewNotes      String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

enum ProductStatus {
  ACTIVE
  DISCONTINUED
}

enum ProductSupplierRole {
  CUT_AND_SEW
  FABRIC_SUPPLIER
  YARN_SUPPLIER
  TRIM_SUPPLIER
  PACKAGING
  OTHER
}

model Product {
  id        String            @id @default(cuid())
  orgId     String
  org       Organization      @relation(fields: [orgId], references: [id])
  name      String
  sku       String
  category  String?
  season    String?
  status    ProductStatus     @default(ACTIVE)
  notes     String?
  // DPP (Digital Product Passport) fields — Phase 6
  dppEnabled       Boolean   @default(false)
  materialComposition String?
  countryOfOrigin    String?
  manufacturingDate  DateTime?
  weight             Float?
  weightUnit         String?   @default("kg")
  recycledContent    Float?    // percentage 0-100
  repairabilityScore Int?      // 1-10
  suppliers ProductSupplier[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@unique([orgId, sku])
}

model ProductSupplier {
  id         String              @id @default(cuid())
  productId  String
  product    Product             @relation(fields: [productId], references: [id])
  supplierId String
  supplier   Supplier            @relation(fields: [supplierId], references: [id])
  role       ProductSupplierRole
  createdAt  DateTime            @default(now())

  @@unique([productId, supplierId, role])
}

// ─── Phase 5: Notifications ───────────────────────────────────────

enum NotificationType {
  DOCUMENT_EXPIRING
  DOCUMENT_EXPIRED
  DOCUMENT_UPLOADED
  DOCUMENT_REVIEWED
  SYSTEM
}

model Notification {
  id        String           @id @default(cuid())
  orgId     String
  org       Organization     @relation(fields: [orgId], references: [id])
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  // Optional link to the related entity
  entityType String?          // "document", "supplier", "product"
  entityId   String?
  createdAt DateTime         @default(now())

  @@index([userId, read])
  @@index([orgId, createdAt])
}
